# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_codebase_autopilot?schema=public"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# GitHub OAuth (Get from: https://github.com/settings/developers)
GITHUB_ID="your-github-oauth-client-id"
GITHUB_SECRET="your-github-oauth-client-secret"

# IBM Bob AI Configuration
IBM_BOB_API_KEY="your-ibm-bob-api-key"
IBM_BOB_API_URL="https://api.ibm-bob.com/v1"

# Optional: AWS S3 for file storage (if not using local storage)
# AWS_S3_BUCKET="your-bucket-name"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="us-east-1"

# Optional: Redis for caching (recommended for production)
# REDIS_URL="redis://localhost:6379"

# Node Environment
NODE_ENV="development"